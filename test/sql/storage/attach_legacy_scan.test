# name: test/sql/storage/attach_legacy_scan.test
# description: Validate removed legacy scan surfaces fail clearly
# group: [storage]

require bigquery

statement error
SET bq_use_legacy_scan=true
----
<REGEX>:.+bq_use_legacy_scan.+

statement error
SET bq_experimental_use_incubating_scan=true
----
<REGEX>:.+bq_experimental_use_incubating_scan.+

statement error
SELECT * FROM bigquery_scan('project.dataset.table', use_legacy_scan=true);
----
<REGEX>:Binder Error: .+use_legacy_scan.+

statement error
SELECT * FROM bigquery_query('project', 'SELECT 1', use_legacy_scan=true);
----
<REGEX>:Binder Error: .+use_legacy_scan.+

statement error
SELECT * FROM bigquery_arrow_scan('project.dataset.table');
----
<REGEX>:Catalog Error: .+bigquery_arrow_scan.+
