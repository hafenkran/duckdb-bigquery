physical_plan	<REGEX>:.*BIGQUERY_QUERY.*

query I
SELECT COUNT(*) FROM bigquery_scan('${BQ_TEST_PROJECT}.${BQ_TEST_DATASET}.aggregate_pushdown', filter := 'i > 1') WHERE j IS NOT NULL;
