# name: test/sql/storage/attach_aggregate_pushdown.test
# description: Validate BigQuery ungrouped aggregate pushdown
# group: [storage]

require bigquery

require-env BQ_TEST_PROJECT

require-env BQ_TEST_DATASET

statement ok
ATTACH 'project=${BQ_TEST_PROJECT} dataset=${BQ_TEST_DATASET}' AS bq (TYPE bigquery);

statement ok
PRAGMA explain_output='physical_only';

statement ok
SET bq_enable_aggregate_pushdown=true;

statement ok
DROP TABLE IF EXISTS bq.${BQ_TEST_DATASET}.aggregate_pushdown;

statement ok
CREATE TABLE bq.${BQ_TEST_DATASET}.aggregate_pushdown AS
SELECT *
FROM (
	VALUES
		(1, 10, true, 'a'),
		(2, NULL, false, 'b'),
		(3, 30, true, 'c'),
		(4, 20, true, NULL)
) t(i, j, b, s);

query II
EXPLAIN SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
physical_plan	<REGEX>:.*BIGQUERY_QUERY.*

query II
EXPLAIN SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
physical_plan	<!REGEX>:.*BIGQUERY_SCAN.*

query III
SELECT COUNT(*), COUNT(1), COUNT(j) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
4	4	3

query II
SELECT SUM(j), CAST(AVG(j) AS BIGINT) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
60	20

query ITT
SELECT MIN(i), MIN(s), MAX(s) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
1	a	c

query II
SELECT BOOL_AND(b), BOOL_OR(b) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
false	true

query II
SELECT COUNT(*), SUM(j) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown WHERE i IN (1, 3, 4);
----
3	60

query II
EXPLAIN SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown WHERE j IS NULL;
----
physical_plan	<REGEX>:.*BIGQUERY_QUERY.*

query I
SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown WHERE j IS NULL;
----
1

query II
SELECT COUNT(*), SUM(j) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown WHERE i > 1 AND i <= 3;
----
2	30

query I
SELECT COUNT(*) + 1 AS c FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
5

query I
SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown HAVING COUNT(*) > 0;
----
4

query I
SELECT COUNT(*) FROM (SELECT i AS renamed_i FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown);
----
4

query I
SELECT COUNT(*) FROM bigquery_scan('${BQ_TEST_PROJECT}.${BQ_TEST_DATASET}.aggregate_pushdown');
----
4

query I
SELECT COUNT(*) FROM bigquery_query('${BQ_TEST_PROJECT}', 'SELECT * FROM ${BQ_TEST_DATASET}.aggregate_pushdown');
----
4

query II
EXPLAIN SELECT i, COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown GROUP BY i;
----
physical_plan	<REGEX>:.*BIGQUERY_SCAN.*

query II
EXPLAIN SELECT COUNT(DISTINCT i) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
physical_plan	<REGEX>:.*BIGQUERY_SCAN.*

query II
EXPLAIN SELECT SUM(i + 1) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
physical_plan	<REGEX>:.*BIGQUERY_SCAN.*

statement ok
SET bq_enable_aggregate_pushdown=false;

query II
EXPLAIN SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
physical_plan	<REGEX>:.*BIGQUERY_SCAN.*

query I
SELECT COUNT(*) FROM bq.${BQ_TEST_DATASET}.aggregate_pushdown;
----
4

statement ok
SET bq_enable_aggregate_pushdown=true;

statement ok
DROP TABLE bq.${BQ_TEST_DATASET}.aggregate_pushdown;
