# name: test/sql/misc/geography_normalize.test
# description: Test local GEOMETRY normalization for BigQuery GEOGRAPHY writes
# group: [misc]

require bigquery

query I
SELECT bigquery_normalize_geography(
    'POLYGON((0 0, 10 0, 10 10, 0 10, 0 0),(2 2, 4 2, 4 6, 2 6, 2 2),(4 2, 6 2, 6 6, 4 6, 4 2))'::GEOMETRY('OGC:CRS84')
);
----
POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0), (2 2, 2 6, 4 6, 6 6, 6 2, 4 2, 2 2))

query I
SELECT bigquery_normalize_geography(
    'POLYGON((0 0, 10 0, 10 10, 0 10, 0 0),(2 2, 4 2, 4 6, 2 6, 2 2),(4 2, 6 2, 6 6, 4 6, 4 4, 4 2))'::GEOMETRY('OGC:CRS84')
);
----
POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0), (2 2, 2 6, 4 6, 6 6, 6 2, 4 2, 2 2))

query I
SELECT bigquery_normalize_geography(
    'POLYGON((0 0, 0 10, 10 10, 10 0, 0 0))'::GEOMETRY('OGC:CRS84')
);
----
POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0))

query I
SELECT bigquery_normalize_geography('POINT (1 2)'::GEOMETRY('OGC:CRS84'));
----
POINT (1 2)
