# name: test/sql/misc/geography_support.test
# description: Test GEOGRAPHY to GEOMETRY type conversion feature
# group: [misc]

require bigquery

require-env BQ_TEST_PROJECT

require-env BQ_TEST_DATASET

# Create a simple table with GEOGRAPHY columns using bigquery_execute
statement ok
FROM bigquery_execute('${BQ_TEST_PROJECT}', '
	CREATE OR REPLACE TABLE `${BQ_TEST_PROJECT}.${BQ_TEST_DATASET}.geography_test` AS
	SELECT * FROM (
		SELECT 1 as id, ST_GEOGPOINT(-122.4194, 37.7749) as geom
		UNION ALL
		SELECT 2 as id, ST_GEOGFROMTEXT("POLYGON((-122.4 37.7, -122.3 37.7, -122.3 37.8, -122.4 37.8, -122.4 37.7))") as geom
	)
');

# Test 1: GEOGRAPHY columns should be returned as GEOMETRY
query II
SELECT id, geom FROM bigquery_scan('${BQ_TEST_PROJECT}.${BQ_TEST_DATASET}.geography_test') ORDER BY id;
----
1	POINT (-122.4194 37.7749)
2	POLYGON ((-122.4 37.7, -122.3 37.7, -122.3 37.8, -122.4 37.8, -122.4 37.7))

# Verify that GEOMETRY cast works on converted columns
query III
SELECT
    id,
    geom,
    typeof(geom) as geom_type
FROM bigquery_scan('${BQ_TEST_PROJECT}.${BQ_TEST_DATASET}.geography_test')
ORDER BY id;
----
1	POINT (-122.4194 37.7749)	GEOMETRY
2	POLYGON ((-122.4 37.7, -122.3 37.7, -122.3 37.8, -122.4 37.8, -122.4 37.7))	GEOMETRY

# Test 2: ATTACH and write to table
statement ok
ATTACH 'project=${BQ_TEST_PROJECT} dataset=${BQ_TEST_DATASET}' AS bq (TYPE bigquery);

statement ok
INSERT INTO bq.${BQ_TEST_DATASET}.geography_test VALUES (4, 'POINT(10 20)'::GEOMETRY)

query II
SELECT * FROM bq.${BQ_TEST_DATASET}.geography_test WHERE id = 4;
----
4	POINT (10 20)

# Test 3: GEOMETRY type mapping is always GEOGRAPHY in BigQuery
statement ok
CREATE OR REPLACE TABLE local_geoms AS
SELECT 1 AS id, 'POINT(1 2)'::GEOMETRY AS geom;

statement ok
DROP TABLE IF EXISTS bq.${BQ_TEST_DATASET}.geography_ctas_false;

statement ok
CREATE TABLE bq.${BQ_TEST_DATASET}.geography_ctas_false AS
SELECT * FROM local_geoms;

query I
SELECT data_type
FROM bigquery_query('${BQ_TEST_PROJECT}', '
  SELECT data_type
  FROM `${BQ_TEST_PROJECT}.${BQ_TEST_DATASET}.INFORMATION_SCHEMA.COLUMNS`
  WHERE table_name = "geography_ctas_false" AND column_name = "geom"
');
----
GEOGRAPHY

# Cleanup
statement ok
FROM bigquery_execute('${BQ_TEST_PROJECT}', 'DROP TABLE `${BQ_TEST_DATASET}.geography_test`');

statement ok
DROP TABLE IF EXISTS bq.${BQ_TEST_DATASET}.geography_ctas_false;

statement ok
DROP TABLE IF EXISTS local_geoms;
